      "metadata": {},
      "outputs": [],
      "source": [
        "# Akses elemen list dengan INDEX (dimulai dari 0)\n",
        "daftar_mahasiswa = [\"Budi Santoso\", \"Ani Wijaya\", \"Citra Dewi\", \"Doni Kurniawan\"]\n",
        "\n",
