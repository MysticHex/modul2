      "outputs": [],
      "source": [
        "# Contoh 1: Hitung mundur sederhana\n",
        "angka = 5\n",
        "print(\"Hitung mundur dengan while:\")\n",
        "while angka > 0:\n",
        "    print(f\"  {angka}...\")\n",
        "    angka -= 1  # Kurangi angka supaya loop berhenti\n",
        "print(\"  Blastoff! 🚀\")"
      ]
    },
    {
      "cell_type": "code">
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Contoh 2: Input validasi (minta input sampai benar)\n",
        "# Simulasi: user harus masukkan angka di antara 1-5\n",
        "angka_rahasia = 3\n",
        "percobaan = 0\n",
        "max_percobaan = 3\n",
        "\n",
        "# Catatan: Dalam notebook, input() tidak bisa digunakan interaktif\n",
        "# Jadi kita simulasikan dengan list\n",
        "daftar_input = [1, 5, 3]  # User coba 1, 5, lalu 3 (benar)\n",
        "idx_input = 0\n",
        "\n",
        "while percobaan < max_percobaan and idx_input < len(daftar_input):\n",
        "    tebakan = daftar_input[idx_input]\n",
        "    percobaan += 1\n",
        "    \n",
        "    if tebakan == angka_rahasia:\n",
        "        print(f\"Benar! Angkanya {angka_rahasia} (percobaan ke-{percobaan})\")\n",
        "        break\n",
        "    else:\n",
        "        print(f\"Salah. Tebakan: {tebakan} (percobaan {percobaan}/{max_percobaan})\")\n",
        "    \n",
        "    idx_input += 1\n",
        "\n",
        "if percobaan == max_percobaan and tebakan != angka_rahasia:\n",
        "    print(f\"Game Over! Jawaban yang benar adalah {angka_rahasia}\")"
      ]
    },
