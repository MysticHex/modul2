        "def label_beban(total_sks):\n",
        "    \"\"\"Labelisasi beban SKS\"\"\"\n",
        "    if total_sks < 12:\n",
        "        return \"Ringan\"\n",
        "    elif total_sks <= 20:\n",
        "        return \"Normal\"\n",
        "    else:\n",
        "        return \"Berat\"\n",
        "\n",
        "# Gunakan fungsi\n",
        "sks_mahasiswa = [3, 4, 3, 2]  # 4 mata kuliah\n",
        "total = hitung_total_sks(sks_mahasiswa)\n",
        "beban = label_beban(total)\n",
        "\n",
        "print(f\"Daftar SKS: {sks_mahasiswa}\")\n",
        "print(f\"Total SKS: {total}\")\n",
        "print(f\"Beban: {beban}\")"
